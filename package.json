{
  "name": "skillspark",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev:backend": "cd backend && go run .",
    "install:all": "cd frontend && bun install",
    "dev:web": "npm run dev -w frontend/apps/web",
    "dev:mobile": "npm run start -w frontend/apps/mobile",
    "generate:api": "npm run generate -w frontend/packages/api-client"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "supabase": "^2.72.7"
  },
  "workspaces": [
    "frontend/apps/*",
    "frontend/packages/*"
  ],
  "dependencies": {
    "nativewind": "^4.2.3",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.7.0",
    "tailwindcss": "^4.2.2"
  }
}
