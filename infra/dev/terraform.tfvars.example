# Copy to terraform.tfvars and fill in. Do not commit terraform.tfvars.

aws_region   = "us-east-2"
project_name = "skillspark"
environment  = "dev"

resend_api_key    = "re_xxxxxxxxxxxx"
expo_access_token = "" # Optional

