{
  "name": "frontend",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun --filter apps/web dev",
    "dev:mobile": "cd apps/mobile && bun run start",
    "generate:api": "cd packages/api-client && bun run generate"
  },
  "dependencies": {
    "@expo-google-fonts/archivo": "^0.4.2",
    "@expo-google-fonts/nunito-sans": "^0.4.2",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@types/node": "^25.5.0",
    "expo-font": "^14.0.11",
    "expo-secure-store": "^55.0.9",
    "i18next": "^25.8.18",
    "react-i18next": "^16.5.8",
    "react-native-maps": "^1.27.1"
  }
}
